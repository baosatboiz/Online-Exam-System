# ============================================================
# Database
# ============================================================
DB_URL=jdbc:postgresql://<host>:<port>/<dbname>?sslmode=require
DB_USERNAME=<your-db-username>
DB_PASSWORD=<your-db-password>

# ============================================================
# Google OAuth2
# ============================================================
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=https://<your-api-domain>/login/oauth2/code/google

# ============================================================
# Supabase Storage
# ============================================================
SUPABASE_URL=https://<your-supabase-project>.supabase.co/storage/v1/object/public/<your-bucket>

# ============================================================
# SePay Payment Gateway
# ============================================================
SEPAY_WEBHOOK_TOKEN=<your-sepay-webhook-token>
SEPAY_BANK_BIN=<your-bank-bin>
SEPAY_ACCOUNT_NUMBER=<your-account-number>
SEPAY_ACCOUNT_NAME=<your-account-name>

# ============================================================
# JWT
# ============================================================
JWT_SECRET=<a-long-random-secret-at-least-32-characters>
JWT_EXPIRATION_SECONDS=3600

# ============================================================
# Application URLs
# ============================================================
FRONTEND_URL=https://www.<your-frontend-domain>
API_URL=https://api.<your-api-domain>

# ============================================================
# CORS (comma-separated list of allowed origins, no spaces)
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://www.<your-frontend-domain>

# ============================================================
# Redis
# ============================================================
REDIS_PASSWORD=<your-redis-password>
