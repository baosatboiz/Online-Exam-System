# ============================================================
# API
# ============================================================
# For local dev, point directly at the backend (no reverse proxy):
# VITE_API_ENDPOINT=http://localhost:8080
# For production / Docker, use the reverse proxy path (or leave unset - defaults to /api):
# VITE_API_ENDPOINT=/api

# ============================================================
# Google OAuth2 redirect
# ============================================================
VITE_GOOGLE_OAUTH2_URL=https://api.<your-api-domain>/oauth2/authorization/google
