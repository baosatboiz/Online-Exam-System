# ============================================================
# API
# ============================================================
For local dev, point directly at the backend (no reverse proxy)
VITE_API_ENDPOINT=http://localhost:8080
# For production / Docker, use the reverse proxy path (default if not set)
# VITE_API_ENDPOINT=/api

# ============================================================
# Google OAuth2 redirect
# ============================================================
VITE_GOOGLE_OAUTH2_URL=https://api.oes-free.me/oauth2/authorization/google
